---
export const prerender = true;

import UserGreeting from '../components/UserGreeting.astro';
import LiveStats from '../components/LiveStats.astro';
import NextJsWidget from '../components/NextJsWidget.astro';
import FallbackCard from '../components/FallbackCard.astro';

const buildTime = new Date().toISOString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Server Islands POC</title>
  </head>
  <body>
    <main>
      <h1>Astro Server Islands</h1>
      <p class="intro">
        This page shell was prerendered at build time. The cards below are server islands
        that load independently after the page appears — including a React widget rendered
        by a separate Next.js app.
      </p>
      <p class="build-time">
        Shell built at: <time datetime={buildTime}>{buildTime}</time>
      </p>

      <section aria-label="Server islands">
        <UserGreeting server:defer name="Alex">
          <FallbackCard slot="fallback" label="Loading greeting..." />
        </UserGreeting>

        <LiveStats server:defer>
          <FallbackCard slot="fallback" label="Loading live stats..." />
        </LiveStats>

        <NextJsWidget server:defer>
          <FallbackCard slot="fallback" label="Loading Next.js widget..." />
        </NextJsWidget>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    font-family: system-ui, sans-serif;
    line-height: 1.5;
    color: #0f172a;
    background: #ffffff;
    margin: 0;
    padding: 2rem;
  }

  main {
    max-width: 640px;
    margin: 0 auto;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: 1.75rem;
  }

  .intro {
    margin: 0 0 0.75rem;
    color: #334155;
  }

  .build-time {
    margin: 0 0 1.5rem;
    font-size: 0.875rem;
    color: #64748b;
  }
</style>
