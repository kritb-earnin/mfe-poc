{
  "name": "astro-server-islands",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n astro,next -c blue,magenta \"npm run dev:astro\" \"npm run dev:next\"",
    "dev:astro": "astro dev",
    "dev:next": "npm run dev --prefix next-widget",
    "build": "astro build",
    "build:next": "npm run build --prefix next-widget",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "astro": "^7.0.7",
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
